# --------------------------------------------------------------------------
# WeatherApp Environment Configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to version control.
# --------------------------------------------------------------------------

# Get a free API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Base URL for OpenWeatherMap (rarely needs changing)
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# Default unit system: "metric" (Celsius) or "imperial" (Fahrenheit)
DEFAULT_UNITS=metric

# Default city shown on first launch
DEFAULT_CITY=London

# Request timeout in seconds
API_TIMEOUT=10

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
